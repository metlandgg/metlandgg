    local function deepScan(objectName)
        local objects = {}
        local scanned = {}
        
        local function scanDescendants(parent)
            for _, obj in pairs(parent:GetDescendants()) do
                if not scanned[obj] then
                    scanned[obj] = true
                    if obj.Name == objectName then
                        if obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("MeshPart") then
                            table.insert(objects, obj)
                        end
                    end
                end
            end
        end
        
        scanDescendants(workspace)
        return objects
    end

    local function deepScanInFolder(folderName, objectName)
        local objects = {}
        local scanned = {}
        
        local folder = workspace:FindFirstChild(folderName)
        if not folder then return objects end
        
        local function scanDescendants(parent)
            for _, obj in pairs(parent:GetDescendants()) do
                if not scanned[obj] then
                    scanned[obj] = true
                    if obj.Name == objectName then
                        if obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("MeshPart") then
                            table.insert(objects, obj)
                        end
                    end
                end
            end
        end
        
        scanDescendants(folder)
        return objects
    end

