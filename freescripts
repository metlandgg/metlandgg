    -- Random string generator
    local function generateRandomHash(length)
        local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
        local hash = ""
        for i = 1, length do
            local rand = math.random(1, #chars)
            hash = hash .. chars:sub(rand, rand)
        end
        return hash
    end
    
    -- Function to add console line
    local function addConsoleLine(text, color)
        local line = Instance.new("TextLabel")
        line.Size = UDim2.new(1, -10, 0, 18)
        line.BackgroundTransparency = 1
        line.Text = "> " .. text
        line.TextColor3 = color or Color3.fromRGB(0, 255, 150)
        line.TextSize = 12
        line.Font = Enum.Font.Code
        line.TextXAlignment = Enum.TextXAlignment.Left
        line.TextTransparency = 1
        line.Parent = consoleFrame
        
        consoleFrame.CanvasSize = UDim2.new(0, 0, 0, consoleList.AbsoluteContentSize.Y)
        consoleFrame.CanvasPosition = Vector2.new(0, consoleList.AbsoluteContentSize.Y)
        
        TweenService:Create(line, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
        
        return line
    end
    
    -- Hacker messages dengan random hashes
    local messages = {
        {"CONNECTING TO NETWORK...", Color3.fromRGB(0, 255, 150)},
        {"SOCKET_ID: " .. generateRandomHash(16), Color3.fromRGB(100, 100, 100)},
        {"ESTABLISHING SECURE TUNNEL...", Color3.fromRGB(0, 200, 255)},
        {"HANDSHAKE: " .. generateRandomHash(24), Color3.fromRGB(100, 100, 100)},
        {"BYPASSING GAME SECURITY...", Color3.fromRGB(255, 200, 0)},
        {"EXPLOIT_KEY: " .. generateRandomHash(20), Color3.fromRGB(100, 100, 100)},
        {"COLLECTION METADATA...", Color3.fromRGB(150, 0, 255)},
        {"METADATA_HASH: " .. generateRandomHash(18), Color3.fromRGB(100, 100, 100)},
        {"INJECTING CORE MODULES...", Color3.fromRGB(0, 255, 150)},
        {"MODULE_ID: " .. generateRandomHash(22), Color3.fromRGB(100, 100, 100)},
        {"LOADING ESP SYSTEMS...", Color3.fromRGB(0, 200, 255)},
        {"ESP_SIGNATURE: " .. generateRandomHash(16), Color3.fromRGB(100, 100, 100)},
        {"INITIALIZING AUTO FARM...", Color3.fromRGB(255, 200, 0)},
        {"FARM_TOKEN: " .. generateRandomHash(20), Color3.fromRGB(100, 100, 100)},
        {"HOOKING REMOTE EVENTS...", Color3.fromRGB(150, 0, 255)},
        {"HOOK_ADDR: " .. generateRandomHash(24), Color3.fromRGB(100, 100, 100)},
        {"PREPARING TELEPORTATION...", Color3.fromRGB(0, 255, 150)},
        {"TP_VECTOR: " .. generateRandomHash(18), Color3.fromRGB(100, 100, 100)},
        {"VERIFYING CREDENTIALS...", Color3.fromRGB(0, 200, 255)},
        {"AUTH_TOKEN: " .. generateRandomHash(28), Color3.fromRGB(100, 100, 100)},
        {"USER DETECTED: " .. plr.Name, Color3.fromRGB(0, 255, 255)},
        {"USER_ID: " .. plr.UserId, Color3.fromRGB(100, 100, 100)},
        {"ACCESS GRANTED!", Color3.fromRGB(0, 255, 0)},
        {"SESSION_KEY: " .. generateRandomHash(32), Color3.fromRGB(100, 100, 100)},
        {"ALL SYSTEMS OPERATIONAL", Color3.fromRGB(0, 255, 150)}
    }
    
    -- Animate loading (10 seconds total)
    task.spawn(function()
        local totalTime = 10
        local delayPerMessage = totalTime / #messages
        
        for i, msg in ipairs(messages) do
            addConsoleLine(msg[1], msg[2])
            
            local progress = (i / #messages) * 100
            progressText.Text = math.floor(progress) .. "%"
            
            TweenService:Create(progressBar, TweenInfo.new(0.3), {
                Size = UDim2.new(progress / 100, 0, 1, 0)
            }):Play()
            
            if i == #messages then
                statusText.Text = "EXECUTION COMPLETE"
                statusText.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
            
            task.wait(delayPerMessage)
        end
        
        task.wait(1)
        
        TweenService:Create(mainFrame, TweenInfo.new(0.5), {
            Position = UDim2.new(0.5, -300, -0.5, 0)
        }):Play()
        
        task.wait(0.5)
        loadingGui:Destroy()
    end)
    
    return loadingGui
end

