    local function addObjectESP(objects, highlightTable, color)
        for _, obj in pairs(objects) do
            if not highlightTable[obj] then
                pcall(function()
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "ObjectESP"
                    highlight.Adornee = obj
                    highlight.FillColor = color
                    highlight.OutlineColor = color
                    highlight.FillTransparency = 0.6
                    highlight.OutlineTransparency = 0
                    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    highlight.Parent = obj
                    highlightTable[obj] = highlight
                end)
            end
        end
    end

    local function removeObjectESP(highlightTable)
        for obj, highlight in pairs(highlightTable) do
            pcall(function() highlight:Destroy() end)
        end
        for k in pairs(highlightTable) do
            highlightTable[k] = nil
        end
    end

    local function refreshObjectESP(findFunc, highlightTable, color, enabled)
        if enabled then
            removeObjectESP(highlightTable)
            local objects = findFunc()
            addObjectESP(objects, highlightTable, color)
        end
    end

