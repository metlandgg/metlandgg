    local function autoCollectGifts()
        while settings.autoCollectGifts do
            pcall(function()
                if giftPickingUp then
                    task.wait(0.5)
                    return
                end

                local char = getChar()
                local root = char:FindFirstChild("HumanoidRootPart")
                
                if not root then
                    task.wait(1)
                    return
                end
                
                local gifts = findGifts()
                if #gifts > 0 then
                    for _, gift in pairs(gifts) do
                        if not settings.autoCollectGifts then break end
                        
                        giftPickingUp = true
                        local giftPos = gift:IsA("Model") and gift:GetPivot().Position or gift.Position
                        
                        root.CFrame = CFrame.new(giftPos + Vector3.new(0, 2, 0))
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.AssemblyAngularVelocity = Vector3.zero
                        task.wait(0.5)
                        
                        for i = 1, 3 do
                            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                            if remotes then
                                local events = remotes:FindFirstChild("Events")
                                if events then
                                    local christmas = events:FindFirstChild("Christmas")
                                    if christmas then
                                        local giftEvent = christmas:FindFirstChild("gift")
                                        if giftEvent then
                                            giftEvent:FireServer()
                                            task.wait(0.1)
                                        end
                                    end
                                end
                            end
                        end
                        
                        task.wait(0.3)
                        
                        local christmasTree = findChristmasTree()
                        if christmasTree then
                            local treePos = christmasTree:IsA("Model") and christmasTree:GetPivot().Position or christmasTree.Position
                            root.CFrame = CFrame.new(treePos + Vector3.new(0, 3, 0))
                            root.AssemblyLinearVelocity = Vector3.zero
                            root.AssemblyAngularVelocity = Vector3.zero
                            task.wait(0.4)
                            
                            for i = 1, 3 do
                                local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                                if remotes then
                                    local events = remotes:FindFirstChild("Events")
                                    if events then
                                        local christmas = events:FindFirstChild("Christmas")
                                        if christmas then
                                            local putdown = christmas:FindFirstChild("putdown")
                                            if putdown then
                                                putdown:FireServer()
                                                task.wait(0.1)
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        
                        task.wait(settings.giftDelay)
                        giftPickingUp = false
                    end
                else
                    task.wait(2)
                end
            end)
            task.wait(0.3)
        end
        giftPickingUp = false
    end

