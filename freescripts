function loadMainScript()
    repeat task.wait() until game:IsLoaded()
    task.wait(0.5)

    local RunService = game:GetService("RunService")
    local Lighting = game:GetService("Lighting")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    -- Load WindUI Library (Mobile-Friendly)
    local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/source.lua"))()

    local Window = WindUI:CreateWindow({
        Title = "Violence District | by metlandgg",
        Icon = "rbxassetid://10723415766",
        Author = "metlandgg",
        Folder = "ViolenceDistrictConfig",
        Size = UDim2.fromOffset(480, 360),
        KeySystem = {
            Key = "23GG",
            Note = "Key already verified",
            SaveKey = true,
            FileName = "VDKey.txt"
        },
        Transparent = false,
        Theme = "Dark",
        SideBarWidth = 170,
        HasOutline = true
    })

    local Main = Window:Tab({
        Name = "Main",
        Icon = "rbxassetid://10723424505",
        Color = Color3.fromRGB(0, 255, 150)
    })

    local ESP = Window:Tab({
        Name = "ESP",
        Icon = "rbxassetid://10723407389",
        Color = Color3.fromRGB(255, 100, 100)
    })

    local Teleport = Window:Tab({
        Name = "Teleport",
        Icon = "rbxassetid://10723415766",
        Color = Color3.fromRGB(100, 150, 255)
    })

    local Auto = Window:Tab({
        Name = "Auto Farm",
        Icon = "rbxassetid://10723424505",
        Color = Color3.fromRGB(255, 200, 0)
    })

    local settings = {
        walkSpeedValue = 16,
        walkSpeedEnabled = false,
        jumpPower = 50,
        noclipEnabled = false,
        fogEnabled = false,
        playerESPEnabled = false,
        playerESPColor = Color3.fromRGB(0, 255, 0),
        killerESPColor = Color3.fromRGB(255, 0, 0),
        generatorESPEnabled = false,
        generatorESPColor = Color3.fromRGB(255, 165, 0),
        palletESPEnabled = false,
        palletESPColor = Color3.fromRGB(255, 0, 0),
        hookESPEnabled = false,
        hookESPColor = Color3.fromRGB(150, 150, 150),
        windowESPEnabled = false,
        windowESPColor = Color3.fromRGB(0, 150, 255),
        giftESPEnabled = false,
        giftESPColor = Color3.fromRGB(255, 215, 0),
        tpToolEnabled = false,
        autoCollectGifts = false,
        autoRepairEnabled = false,
        antiFail = false,
        giftDelay = 2
    }

    local function getChar()
        return plr.Character or plr.CharacterAdded:Wait()
    end

    local oldFog = {}
    local noclipConnection
    local walkSpeedConnection
    
    Main:Section({
        Name = "Movement"
    })
    
    Main:Toggle({
        Name = "Walk Speed",
        Flag = "WalkSpeedEnabled",
        Value = false,
        Callback = function(value)
            settings.walkSpeedEnabled = value
            
            if value then
                if walkSpeedConnection then
                    walkSpeedConnection:Disconnect()
                end
                
                walkSpeedConnection = RunService.Heartbeat:Connect(function()
                    if settings.walkSpeedEnabled then
                        pcall(function()
                            local char = plr.Character
                            if char then
                                local hum = char:FindFirstChild("Humanoid")
                                if hum then
                                    hum.WalkSpeed = settings.walkSpeedValue
                                end
                            end
                        end)
                    end
                end)
            else
                if walkSpeedConnection then
                    walkSpeedConnection:Disconnect()
                    walkSpeedConnection = nil
                end
                
                pcall(function()
                    local char = plr.Character
                    if char then
                        local hum = char:FindFirstChild("Humanoid")
                        if hum then
                            hum.WalkSpeed = 16
                        end
                    end
                end)
            end
        end
    })

    Main:Slider({
        Name = "Speed Value",
        Flag = "WalkSpeed",
        Min = 16,
        Max = 500,
        Value = 16,
        Callback = function(value)
            settings.walkSpeedValue = value
            if settings.walkSpeedEnabled then
                pcall(function()
                    local char = plr.Character
                    if char then
                        local hum = char:FindFirstChild("Humanoid")
                        if hum then
                            hum.WalkSpeed = value
                        end
                    end
                end)
            end
        end
    })

    Main:Slider({
        Name = "Jump Power",
        Flag = "JumpPower",
        Min = 0,
        Max = 500,
        Value = 50,
        Callback = function(value)
            settings.jumpPower = value
            local char = getChar()
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.JumpPower = value
            end
        end
    })

    Main:Toggle({
        Name = "NoClip",
        Flag = "Noclip",
        Value = false,
        Callback = function(value)
            settings.noclipEnabled = value
            
            if settings.noclipEnabled then
                noclipConnection = RunService.Stepped:Connect(function()
                    local char = getChar()
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end)
            else
                if noclipConnection then
                    noclipConnection:Disconnect()
                end
                local char = getChar()
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = true
                    end
                end
            end
        end
    })

    Main:Section({
        Name = "Visuals"
    })

    Main:Toggle({
        Name = "Remove Fog",
        Flag = "RemoveFog",
        Value = false,
        Callback = function(value)
            settings.fogEnabled = value
            
            if value then
                oldFog.FogEnd = Lighting.FogEnd
                oldFog.FogStart = Lighting.FogStart
                Lighting.FogEnd = 100000
                Lighting.FogStart = 0
            else
                Lighting.FogEnd = oldFog.FogEnd or 10000
                Lighting.FogStart = oldFog.FogStart or 0
            end
        end
    })

    local tpTool
    Main:Toggle({
        Name = "TP Tool",
        Flag = "TPTool",
        Value = false,
        Callback = function(value)
            settings.tpToolEnabled = value
            
            if settings.tpToolEnabled then
                tpTool = Instance.new("Tool")
                tpTool.Name = "TP Tool"
                tpTool.RequiresHandle = false
                tpTool.CanBeDropped = false
                
                tpTool.Activated:Connect(function()
                    local mouse = plr:GetMouse()
                    if mouse.Target then
                        pcall(function()
                            local char = getChar()
                            local root = char:FindFirstChild("HumanoidRootPart")
                            root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
                        end)
                    end
                end)
                
                tpTool.Parent = plr.Backpack
                local char = getChar()
                char.Humanoid:EquipTool(tpTool)
            else
                if tpTool then
                    tpTool:Destroy()
                    tpTool = nil
                end
            end
        end
    })

    local espHighlights = {}
    local espConnections = {}

    local function isKiller(player)
        if not player or not player.Team then return false end
        return player.Team.Name == "Killer"
    end

    local function addPlayerESP(player)
        if player == plr then return end
        
        local function createESP(character)
            task.wait(0.5)
            
            if espHighlights[player] then
                pcall(function() espHighlights[player]:Destroy() end)
            end
            
            local killer = isKiller(player)
            
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESP_" .. player.Name
            highlight.Adornee = character
            highlight.FillColor = killer and settings.killerESPColor or settings.playerESPColor
            highlight.OutlineColor = killer and settings.killerESPColor or settings.playerESPColor
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = character
            
            espHighlights[player] = highlight
            
            task.spawn(function()
                while character.Parent and highlight.Parent do
                    local newKiller = isKiller(player)
                    if newKiller ~= killer then
                        killer = newKiller
                        highlight.FillColor = killer and settings.killerESPColor or settings.playerESPColor
                        highlight.OutlineColor = killer and settings.killerESPColor or settings.playerESPColor
                    end
                    task.wait(3)
                end
            end)
            
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ESP_Distance_" .. player.Name
                billboard.Adornee = hrp
                billboard.Size = UDim2.new(0, 200, 0, 70)
                billboard.StudsOffset = Vector3.new(0, 3, 0)
                billboard.AlwaysOnTop = true
                billboard.Parent = hrp
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = player.Name
                nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                nameLabel.TextSize = 16
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextStrokeTransparency = 0.3
                nameLabel.Parent = billboard
                
                local distLabel = Instance.new("TextLabel")
                distLabel.Size = UDim2.new(1, 0, 0.5, 0)
                distLabel.Position = UDim2.new(0, 0, 0.5, 0)
                distLabel.BackgroundTransparency = 1
                distLabel.Text = "0m"
                distLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
                distLabel.TextSize = 14
                distLabel.Font = Enum.Font.Gotham
                distLabel.TextStrokeTransparency = 0.3
                distLabel.Parent = billboard
                
                task.spawn(function()
                    while billboard.Parent and hrp.Parent do
                        local char = getChar()
                        local root = char:FindFirstChild("HumanoidRootPart")
                        if root then
                            local dist = (hrp.Position - root.Position).Magnitude
                            distLabel.Text = string.format("%.1fm", dist)
                        end
                        task.wait(2)
                    end
                end)
            end
        end
        
        if player.Character then
            createESP(player.Character)
        end
        local conn = player.CharacterAdded:Connect(createESP)
        table.insert(espConnections, conn)
    end

    local function removePlayerESP()
        for player, highlight in pairs(espHighlights) do
            pcall(function()
                highlight:Destroy()
                local char = player.Character
                if char then
                    local billboard = char:FindFirstChild("HumanoidRootPart")
                    if billboard then
                        for _, child in pairs(billboard:GetChildren()) do
                            if child.Name:match("ESP_Distance") then
                                child:Destroy()
                            end
                        end
                    end
                end
            end)
        end
        for _, conn in pairs(espConnections) do
            conn:Disconnect()
        end
        espHighlights = {}
        espConnections = {}
    end

