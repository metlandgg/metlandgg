    local function autoRepairGenerator()
        while settings.autoRepairEnabled do
            pcall(function()
                local generators = findGenerators()
                local incompleteGens = {}
                
                for _, gen in pairs(generators) do
                    if not isGeneratorComplete(gen) then
                        table.insert(incompleteGens, gen)
                    end
                end
                
                if #incompleteGens > 0 and not currentRepairingGen then
                    local targetGen = incompleteGens[1]
                    currentRepairingGen = targetGen
                    
                    local char = getChar()
                    local root = char:FindFirstChild("HumanoidRootPart")
                    
                    if root then
                        local targetPoint = findGeneratorPoint(targetGen)
                        local targetPos
                        
                        if targetPoint then
                            targetPos = targetPoint:IsA("BasePart") and targetPoint.Position or targetPoint:GetPivot().Position
                        else
                            targetPos = targetGen:IsA("Model") and targetGen:GetPivot().Position or targetGen.Position
                        end
                        
                        root.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.AssemblyAngularVelocity = Vector3.zero
                        task.wait(0.5)
                        
                        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                        if remotes then
                            local genFolder = remotes:FindFirstChild("Generator")
                            if genFolder then
                                local repairEvent = genFolder:FindFirstChild("RepairEvent")
                                if repairEvent then
                                    for i = 1, 2 do
                                        repairEvent:FireServer(targetGen, true)
                                        task.wait(0.1)
                                    end
                                    
                                    local startTime = tick()
                                    while settings.autoRepairEnabled and not isGeneratorComplete(targetGen) and (tick() - startTime) < 30 do
                                        repairEvent:FireServer(targetGen, true)
                                        task.wait(1)
                                    end
                                    
                                    if isGeneratorComplete(targetGen) then
                                        currentRepairingGen = nil
                                        task.wait(1)
                                    else
                                        repairEvent:FireServer(targetGen, false)
                                        currentRepairingGen = nil
                                        task.wait(0.5)
                                    end
                                end
                            end
                        end
                    end
                else
                    if currentRepairingGen and isGeneratorComplete(currentRepairingGen) then
                        currentRepairingGen = nil
                    end
                    task.wait(1)
                end
            end)
            task.wait(0.3)
        end
        currentRepairingGen = nil
    end

