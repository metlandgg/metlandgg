    local function instantWin()
        local finishLines = findFinishLine()
        
        if #finishLines > 0 then
            local finishLine = finishLines[1]
            local char = getChar()
            local root = char:FindFirstChild("HumanoidRootPart")
            
            if root then
                local originalNoclip = settings.noclipEnabled
                
                if not noclipConnection then
                    noclipConnection = RunService.Stepped:Connect(function()
                        local c = getChar()
                        for _, part in pairs(c:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end)
                end
                
                local finishPos = finishLine:IsA("Model") and finishLine:GetPivot().Position or finishLine.Position
                root.CFrame = CFrame.new(finishPos)
                
                task.wait(1)
                
                if not originalNoclip and noclipConnection then
                    noclipConnection:Disconnect()
                    noclipConnection = nil
                    local c = getChar()
                    for _, part in pairs(c:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = true
                        end
                    end
                end
                
                WindUI:Notify({
                    Title = "Instant Win",
                    Content = "Teleported to finish!",
                    Duration = 2
                })
            end
        else
            WindUI:Notify({
                Title = "Error",
                Content = "Finish line not found!",
                Duration = 2
            })
        end
    end

