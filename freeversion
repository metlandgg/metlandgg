                            local kr = nk.Character:FindFirstChild("HumanoidRootPart")
                            if kr then
                                local behindPos = kr.Position + (kr.CFrame.LookVector * -2)
                                root.CFrame = CFrame.new(behindPos)
                                if hookPosition then
