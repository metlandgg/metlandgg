SurvivorTab:CreateToggle({
    Name = "Auto Perfect SkillCheck",
    CurrentValue = false,
    Flag = "AutoPerfect",
    Callback = function(v)
        s.autoPerfect = v
        if conns.sc then conns.sc:Disconnect() conns.sc = nil end
        if not v then return end

        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if not remotes then return end

        local genRes = remotes:FindFirstChild("Generator") and remotes.Generator:FindFirstChild("SkillCheckResultEvent")
        local healRes = remotes:FindFirstChild("Healing") and remotes.Healing:FindFirstChild("SkillCheckResultEvent")
        local genSC = remotes:FindFirstChild("Generator") and remotes.Generator:FindFirstChild("SkillCheckEvent")
        local healSC = remotes:FindFirstChild("Healing") and remotes.Healing:FindFirstChild("SkillCheckEvent")

        local hasFired = false
        local lastCheck = 0

        local c1 = RunService.RenderStepped:Connect(function()
            if not s.autoPerfect then return end
            pcall(function()
                local PlayerGui = plr.PlayerGui
                local gui = PlayerGui:FindFirstChild("SkillCheckPromptGui")
                    or PlayerGui:FindFirstChild("SkillCheckPromptGui-con")
                if not gui or not gui.Enabled then
                    hasFired = false
                    return
                end

                local check = gui:FindFirstChild("Check")
                if not check or not check.Visible then
                    hasFired = false
                    return
                end

                local goal = check:FindFirstChild("Goal")
                local line = check:FindFirstChild("Line")
                if not goal or not line then
                    hasFired = false
                    return
                end

                if hasFired then return end

                local goalRot = goal.Rotation % 360
                local lineRot = line.Rotation % 360
                if goalRot < 0 then goalRot += 360 end
                if lineRot < 0 then lineRot += 360 end

                local goalAbs = goal.AbsoluteSize.X
                local halfGoal
                if goalAbs > 0 then
                    halfGoal = goalAbs * 0.12
                else
                    local checkSize = check.AbsoluteSize.X > 0 and check.AbsoluteSize.X or 300
                    halfGoal = checkSize * goal.Size.X.Scale * 0.12
                end
                halfGoal = math.max(halfGoal, 18)

                local diff = lineRot - goalRot
                if diff > 180 then diff -= 360 end
                if diff < -180 then diff += 360 end

                local absDiff = math.abs(diff)

                local lastLineRot = check:GetAttribute("_lastLineRot")
                local lastTick = check:GetAttribute("_lastTick")
                local lineSpeed = 0

                local now = tick()
                if lastLineRot and lastTick then
                    local dtRot = lineRot - lastLineRot
                    if dtRot > 180 then dtRot -= 360 end
                    if dtRot < -180 then dtRot += 360 end
                    local dtTime = now - lastTick
                    if dtTime > 0 then
                        lineSpeed = dtRot / dtTime
                    end
                end

                pcall(function()
                    check:SetAttribute("_lastLineRot", lineRot)
                    check:SetAttribute("_lastTick", now)
                end)

                local frameLatency = math.abs(lineSpeed) > 100 and 0.03 or 0.05
                local predictedDiff = diff - lineSpeed * frameLatency
                if predictedDiff > 180 then predictedDiff -= 360 end
                if predictedDiff < -180 then predictedDiff += 360 end

                local absPredicted = math.abs(predictedDiff)

                if absPredicted <= halfGoal then
                    hasFired = true
                    task.spawn(function()
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                        task.wait(0.05)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                        task.wait(0.8)
                        hasFired = false
                    end)
                end
            end)
        end)

        local c2, c3
        if genSC and genRes then
            c2 = genSC.OnClientEvent:Connect(function()
                if not s.autoPerfect then return end
                task.wait(0.08)
                pcall(function() genRes:FireServer(true) end)
            end)
        end
        if healSC and healRes then
            c3 = healSC.OnClientEvent:Connect(function()
                if not s.autoPerfect then return end
                task.wait(0.08)
                pcall(function() healRes:FireServer(true) end)
            end)
        end

        conns.sc = {Disconnect = function()
            c1:Disconnect()
            if c2 then c2:Disconnect() end
            if c3 then c3:Disconnect() end
        end}
    end
})

