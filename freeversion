            if not root then return end
            local gens = findGenerators()
            local nearest, nd = nil, math.huge
            for _, g in pairs(gens) do
                local gp = g:IsA("Model") and g:GetPivot().Position or g.Position
                local d = (root.Position-gp).Magnitude
                if d < nd then nd=d nearest=g end
            end
            if nearest then bg:FireServer(nearest) end
        end)
    end
})

