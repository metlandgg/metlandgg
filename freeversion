local function deepScan(name)
    local result = {}
    local scanned = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if not scanned[obj] then
            scanned[obj] = true
            if obj.Name == name and (obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("MeshPart")) then
                table.insert(result, obj)
            end
        end
    end
    return result
end

local _cacheGens, _cacheWins, _cachePals, _cacheHooks, _cacheFL = {},{},{},{},{}
local _lastCacheTime = 0
local CACHE_TTL = 6

local function refreshCache()
    local now = tick()
    if now - _lastCacheTime < CACHE_TTL then return end
    _lastCacheTime = now

    _cacheGens = {}
    _cacheWins = {}
    _cachePals = {}
    _cacheHooks = {}
    _cacheFL = {}

    local map = workspace:FindFirstChild("Map")
    local scanRoot = map or workspace

    for _, obj in pairs(scanRoot:GetDescendants()) do
        local n = obj.Name
        if n == "Generator" and obj:IsA("Model") then
            table.insert(_cacheGens, obj)
        elseif n == "Window" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            table.insert(_cacheWins, obj)
        elseif n == "Palletwrong" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            table.insert(_cachePals, obj)
        elseif n == "Hook" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            table.insert(_cacheHooks, obj)
        elseif n == "Fininshline" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            table.insert(_cacheFL, obj)
        end
    end
end

local function findGenerators() refreshCache() return _cacheGens end
local function findWindows() refreshCache() return _cacheWins end
local function findPallets() refreshCache() return _cachePals end
local function findHooks() refreshCache() return _cacheHooks end
local function findFinishLine()
    refreshCache()
    if #_cacheFL > 0 then return _cacheFL end
    local map = workspace:FindFirstChild("Map")
    if not map then return {} end
    local result = {}
    for _, obj in pairs(map:GetDescendants()) do
        if obj.Name == "Fininshline" then
            table.insert(result, obj)
        end
    end
    _cacheFL = result
    return result
end

local function isGenComplete(gen)
    local progress = gen:GetAttribute("RepairProgress")
    if progress then return progress >= 100 end
    local pv = gen:FindFirstChild("Progress")
    if pv and pv:IsA("NumberValue") then return pv.Value >= 100 end
    return false
end

local function getGenProgress(gen)
    return gen:GetAttribute("RepairProgress") or 0
end

local function isGenPaused(gen)
    return gen:GetAttribute("ProgressPaused") == true
end

local function findBestGenPoint(gen)
    local char = plr.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local bestPoint = nil
    for _, child in pairs(gen:GetChildren()) do
        if child.Name:match("GeneratorPoint") and child:IsA("BasePart") then
            local isRepairing = child:GetAttribute("IsRepairing")
            if not isRepairing then
                if not bestPoint then
                    bestPoint = child
                elseif root then
                    local dNew = (child.Position - root.Position).Magnitude
                    local dCur = (bestPoint.Position - root.Position).Magnitude
                    if dNew < dCur then bestPoint = child end
                end
            end
        end
    end
    if not bestPoint then
        for _, child in pairs(gen:GetChildren()) do
            if child.Name:match("GeneratorPoint") and child:IsA("BasePart") then
                return child
            end
        end
    end
    return bestPoint
end

local function findBestGen()
    local gens = findGenerators()
    local best = nil
    local bestProgress = -1
    for _, gen in pairs(gens) do
        local progress = getGenProgress(gen)
        if progress >= 100 then continue end
        if isGenPaused(gen) then continue end
        if progress > bestProgress then
            bestProgress = progress
            best = gen
        end
    end
    return best
end

local function findGenPoint(gen)
    return findBestGenPoint(gen)
end

local function isKillerTeam(p)
    return p and p.Team and p.Team.Name == "Killer"
end

local function isHooked(char)
    if not char then return false end
    local hookedProgress = char:GetAttribute("HookedProgress")
    if hookedProgress and hookedProgress >= 100 then return true end
    local hookCount = char:GetAttribute("HookCount")
    if hookCount and hookCount > 0 then
        local hum = char:FindFirstChild("Humanoid")
        if hum and (hum.PlatformStand or hum.Sit) then return true end
    end
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("Weld") and v.Name == "Hurtbox" then
            if v.Part0 and v.Part0.Name == "HRP_Clone" then
                return true
            end
        end
    end
    return false
end

