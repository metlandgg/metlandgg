ESPTab:CreateSection("Objects")

ESPTab:CreateToggle({
    Name = "Generator ESP",
    CurrentValue = false,
    Flag = "GenESP",
    Callback = function(v)
        s.genESP = v
        if conns.genESP then conns.genESP:Disconnect() conns.genESP = nil end

        if not v then
            removeObjectESP(genHL)
            for _, bb in pairs(workspace:GetDescendants()) do
                if bb:IsA("BillboardGui") and bb.Name == "GenESP_Progress" then
                    bb:Destroy()
                end
            end
            return
        end

        local function setupGenESP(gen)
            if genHL[gen] then return end
            pcall(function()
                local h = Instance.new("Highlight")
                h.Adornee = gen
                h.FillColor = Color3.fromRGB(255,165,0)
                h.OutlineColor = Color3.fromRGB(255,165,0)
                h.FillTransparency = 0.75
                h.OutlineTransparency = 0.15
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Parent = gen
                genHL[gen] = h

                local mesh = gen:FindFirstChildOfClass("MeshPart") or gen:FindFirstChildOfClass("BasePart")
                if not mesh then
                    for _, c in pairs(gen:GetChildren()) do
                        if c:IsA("BasePart") then mesh = c break end
                    end
                end
                if not mesh then return end

                local existing = mesh:FindFirstChild("GenESP_Progress")
                if existing then existing:Destroy() end

                local bb = Instance.new("BillboardGui")
                bb.Name = "GenESP_Progress"
                bb.Adornee = mesh
                bb.Size = UDim2.new(0, 120, 0, 40)
                bb.StudsOffset = Vector3.new(0, 4, 0)
                bb.AlwaysOnTop = true
                bb.Parent = mesh

                local bg = Instance.new("Frame", bb)
                bg.Size = UDim2.new(1, 0, 1, 0)
                bg.BackgroundTransparency = 1
                bg.BorderSizePixel = 0

                local barBg = Instance.new("Frame", bg)
                barBg.Size = UDim2.new(0.9, 0, 0, 8)
                barBg.Position = UDim2.new(0.05, 0, 0.6, 0)
                barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                barBg.BackgroundTransparency = 0.4
                barBg.BorderSizePixel = 0
                Instance.new("UICorner", barBg).CornerRadius = UDim.new(1, 0)

                local barFill = Instance.new("Frame", barBg)
                barFill.Size = UDim2.new(0, 0, 1, 0)
                barFill.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
                barFill.BorderSizePixel = 0
                Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)

                local label = Instance.new("TextLabel", bg)
                label.Size = UDim2.new(1, 0, 0.55, 0)
                label.BackgroundTransparency = 1
                label.Text = "Gen 0%"
                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                label.TextSize = 13
                label.Font = Enum.Font.GothamBold
                label.TextStrokeTransparency = 0.2

                task.spawn(function()
                    while bb.Parent and s.genESP do
                        pcall(function()
                            local progress = gen:GetAttribute("RepairProgress") or 0
                            local ratio = math.clamp(progress / 100, 0, 1)
                            barFill.Size = UDim2.new(ratio, 0, 1, 0)
                            label.Text = string.format("%.0f%%", progress)
                            if progress >= 100 then
                                bb.Enabled = false
                                h.FillColor = Color3.fromRGB(0, 255, 100)
                                h.OutlineColor = Color3.fromRGB(0, 255, 100)
                                h.FillTransparency = 0.9
                            elseif progress > 50 then
                                barFill.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                                label.TextColor3 = Color3.fromRGB(255, 200, 0)
                                h.FillColor = Color3.fromRGB(255, 200, 0)
                                h.OutlineColor = Color3.fromRGB(255, 200, 0)
                            else
                                barFill.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
                                label.TextColor3 = Color3.fromRGB(255, 165, 0)
                                h.FillColor = Color3.fromRGB(255, 165, 0)
                                h.OutlineColor = Color3.fromRGB(255, 165, 0)
                            end
                        end)
                        task.wait(0.3)
                    end
                    bb:Destroy()
                end)
            end)
        end

        local gens = findGenerators()
        for _, g in pairs(gens) do setupGenESP(g) end

        local lastGenCheck = 0
        conns.genESP = RunService.Heartbeat:Connect(function()
            if not s.genESP then return end
            if tick() - lastGenCheck < 3 then return end
            lastGenCheck = tick()
            for _, g in pairs(findGenerators()) do
                if not genHL[g] then setupGenESP(g) end
            end
        end)
    end
})

