local function addObjectESP(objects, tbl, color)
    for _, obj in pairs(objects) do
        if not tbl[obj] then
            pcall(function()
                local h = Instance.new("Highlight")
                h.Adornee = obj
                h.FillColor = color
                h.OutlineColor = color
                h.FillTransparency = 0.75
                h.OutlineTransparency = 0.15
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Parent = obj
                tbl[obj] = h
            end)
        end
    end
end

local function removeObjectESP(tbl)
    for _, h in pairs(tbl) do pcall(function() h:Destroy() end) end
    for k in pairs(tbl) do tbl[k] = nil end
end

local function addPlayerESP(player)
    if player == plr then return end
    local function makeESP(char)
        task.wait(0.5)
        if espHL[player] then pcall(function() espHL[player]:Destroy() end) end
        local isK = isKillerTeam(player)
        local h = Instance.new("Highlight")
        h.Adornee = char
        h.FillColor = isK and Color3.fromRGB(255,60,60) or Color3.fromRGB(60,255,120)
        h.OutlineColor = h.FillColor
        h.FillTransparency = 0.72
        h.OutlineTransparency = 0.1
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = char
        espHL[player] = h
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bb = Instance.new("BillboardGui")
            bb.Adornee = hrp
            bb.Size = UDim2.new(0,180,0,55)
            bb.StudsOffset = Vector3.new(0,3,0)
            bb.AlwaysOnTop = true
            bb.Parent = hrp
            local nl = Instance.new("TextLabel", bb)
            nl.Size = UDim2.new(1,0,0.5,0)
            nl.BackgroundTransparency = 1
            nl.Text = player.Name
            nl.TextColor3 = Color3.fromRGB(255,255,255)
            nl.TextSize = 14
            nl.Font = Enum.Font.GothamBold
            nl.TextStrokeTransparency = 0.2
            local dl = Instance.new("TextLabel", bb)
            dl.Size = UDim2.new(1,0,0.5,0)
            dl.Position = UDim2.new(0,0,0.5,0)
            dl.BackgroundTransparency = 1
            dl.Text = "0m"
            dl.TextColor3 = isK and Color3.fromRGB(255,150,150) or Color3.fromRGB(150,255,180)
            dl.TextSize = 12
            dl.Font = Enum.Font.Gotham
            dl.TextStrokeTransparency = 0.2
            task.spawn(function()
                while bb.Parent and hrp.Parent do
                    local mc = getChar()
                    local mr = mc:FindFirstChild("HumanoidRootPart")
                    if mr then dl.Text = string.format("%.0fm",(hrp.Position-mr.Position).Magnitude) end
                    task.wait(0.5)
                end
            end)
        end
        task.spawn(function()
            while char.Parent and h.Parent do
                local newK = isKillerTeam(player)
                if newK ~= isK then
                    isK = newK
                    h.FillColor = isK and Color3.fromRGB(255,60,60) or Color3.fromRGB(60,255,120)
                    h.OutlineColor = h.FillColor
                end
                task.wait(3)
            end
        end)
    end
    if player.Character then makeESP(player.Character) end
    local c = player.CharacterAdded:Connect(makeESP)
    table.insert(espConns, c)
end

local function removePlayerESP()
    for _, h in pairs(espHL) do pcall(function() h:Destroy() end) end
    for _, c in pairs(espConns) do c:Disconnect() end
    espHL = {} espConns = {}
end

