        if not v then return end

        local wasHooked = false
        local executed = false
        local hookPosition = nil
        local ghostConn = nil
        local hookPhaseConn = nil

        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        local hookPhaseRemote = remotes and remotes:FindFirstChild("Carry") and remotes.Carry:FindFirstChild("HookPhase")

        if hookPhaseRemote then
            hookPhaseConn = hookPhaseRemote.OnClientEvent:Connect(function(phase)
                if not s.antiCamp then return end
                local char = getChar()
                if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                if phase == 1 or phase == "1" or phase == "camping" or phase == true then
                    if not executed then
                        executed = true
                        hookPosition = root.CFrame

                        task.spawn(function()
                            task.wait(0.5)

                            local nk, nd = nil, math.huge
                            for _, p in pairs(Players:GetPlayers()) do
                                if p == plr then continue end
                                if not isKillerTeam(p) then continue end
                                if not p.Character then continue end
                                local kr = p.Character:FindFirstChild("HumanoidRootPart")
                                if not kr then continue end
                                local d = (root.Position-kr.Position).Magnitude
                                if d < nd then nd=d nk=p end
                            end

                            if nk and nk.Character then
