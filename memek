    -- TELEPORT TAB CONTENT
    local function isGeneratorComplete(generator)
        local progressValue = generator:FindFirstChild("Progress")
        if progressValue and progressValue:IsA("NumberValue") then
            return progressValue.Value >= 100
        end

        local genGui = generator:FindFirstChildOfClass("BillboardGui")
        if genGui then
            local textLabel = genGui:FindFirstChildOfClass("TextLabel")
            if textLabel and textLabel.Text:match("100%%") then
                return true
            end
        end

        return false
    end

    local function findGeneratorPoint(generator)
        for i = 1, 4 do
            local point = generator:FindFirstChild("GeneratorPoint" .. i)
            if point then
                return point
            end
        end
        return nil
    end

    createButton(teleportTab, "TP to Generator", function()
        local generators = findGenerators()
        local incompleteGens = {}

        for _, gen in pairs(generators) do
            if not isGeneratorComplete(gen) then
                table.insert(incompleteGens, gen)
            end
        end

        if #incompleteGens > 0 then
            local randomGen = incompleteGens[math.random(1, #incompleteGens)]
            local char = getChar()
            local root = char:FindFirstChild("HumanoidRootPart")

            if root then
                local targetPoint = findGeneratorPoint(randomGen)
                local targetPos

                if targetPoint then
                    targetPos = targetPoint:IsA("BasePart") and targetPoint.Position or targetPoint:GetPivot().Position
                else
                    targetPos = randomGen:IsA("Model") and randomGen:GetPivot().Position or randomGen.Position
                end

                root.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
            end
        end
    end)

