    -- AUTO TAB CONTENT
    local currentRepairingGen = nil
    local autoRepairRunning = false

    local function autoRepairGenerator()
        autoRepairRunning = true
        while settings.autoRepairEnabled and autoRepairRunning do
            local success = pcall(function()
                local generators = findGenerators()
                local incompleteGens = {}

                for _, gen in pairs(generators) do
                    if not isGeneratorComplete(gen) then
                        table.insert(incompleteGens, gen)
                    end
                end

                if #incompleteGens > 0 then
                    local targetGen = incompleteGens[1]
                    currentRepairingGen = targetGen

                    local char = getChar()
                    local root = char:FindFirstChild("HumanoidRootPart")

                    if root then
                        local targetPoint = findGeneratorPoint(targetGen)
                        local targetPos

                        if targetPoint then
                            targetPos = targetPoint:IsA("BasePart") and targetPoint.Position or targetPoint:GetPivot().Position
                        else
                            targetPos = targetGen:IsA("Model") and targetGen:GetPivot().Position or targetGen.Position
                        end

                        root.CFrame = CFrame.new(targetPos)
                        task.wait(0.2)

                        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                        if remotes then
                            local genFolder = remotes:FindFirstChild("Generator")
                            if genFolder then
                                local repairEvent = genFolder:FindFirstChild("RepairEvent")
                                local repairAnim = genFolder:FindFirstChild("RepairAnim")
                                
                                if repairEvent then
                                    repairEvent:FireServer(targetGen, true)
                                    
                                    if repairAnim then
                                        repairAnim:FireServer()
                                    end
                                    
                                    task.wait(0.3)
                                    
                                    local startTime = tick()
                                    local lastProgress = 0
                                    
                                    while settings.autoRepairEnabled and not isGeneratorComplete(targetGen) and (tick() - startTime) < 80 do
                                        if not settings.autoRepairEnabled then break end
                                        
                                        local char2 = getChar()
                                        local root2 = char2:FindFirstChild("HumanoidRootPart")
                                        if root2 then
                                            root2.CFrame = CFrame.new(targetPos)
                                            root2.AssemblyLinearVelocity = Vector3.zero
                                            root2.AssemblyAngularVelocity = Vector3.zero
                                        end
                                        
                                        repairEvent:FireServer(targetGen, true)
                                        
                                        local currentProgress = 0
                                        local progressVal = targetGen:FindFirstChild("Progress")
                                        if progressVal and progressVal:IsA("NumberValue") then
                                            currentProgress = progressVal.Value
                                        end
                                        
                                        if currentProgress == lastProgress and currentProgress < 100 then
                                            repairEvent:FireServer(targetGen, false)
                                            task.wait(0.1)
                                            repairEvent:FireServer(targetGen, true)
                                        end
                                        
                                        lastProgress = currentProgress
                                        task.wait(0.3)
                                    end

                                    repairEvent:FireServer(targetGen, false)
                                    currentRepairingGen = nil
                                    task.wait(1)
                                end
                            end
                        end
                    end
                else
                    currentRepairingGen = nil
                    task.wait(3)
                end
            end)
            
            if not success then
                currentRepairingGen = nil
                task.wait(2)
            end
        end
        currentRepairingGen = nil
        autoRepairRunning = false
    end

    createToggle(autoTab, "Auto Repair Gen", function(value)
        settings.autoRepairEnabled = value
        if value then
            task.spawn(autoRepairGenerator)
        else
            autoRepairRunning = false
            
            pcall(function()
                local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                if remotes then
                    local genFolder = remotes:FindFirstChild("Generator")
                    if genFolder then
                        local repairEvent = genFolder:FindFirstChild("RepairEvent")
                        if repairEvent and currentRepairingGen then
                            repairEvent:FireServer(currentRepairingGen, false)
                        end
                    end
                end
            end)
            
            currentRepairingGen = nil
        end
    end)

